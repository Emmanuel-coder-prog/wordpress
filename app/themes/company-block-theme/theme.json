{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "760px",
      "wideSize": "1280px"
    },
    "color": {
      "defaultPalette": false,
      "palette": [
        {
          "slug": "background",
          "name": "Background",
          "color": "#f7f7f5"
        },
        {
          "slug": "foreground",
          "name": "Foreground",
          "color": "#171717"
        },
        {
          "slug": "primary",
          "name": "Primary",
          "color": "#1545ac"
        },
        {
          "slug": "accent",
          "name": "Accent",
          "color": "#50e378"
        }
      ]
    },
    "spacing": {
      "units": ["px", "rem", "%", "vw", "vh"],
      "spacingSizes": [
        {
          "slug": "20",
          "name": "Small",
          "size": "0.75rem"
        },
        {
          "slug": "40",
          "name": "Medium",
          "size": "1.5rem"
        },
        {
          "slug": "60",
          "name": "Large",
          "size": "3rem"
        },
        {
          "slug": "80",
          "name": "Extra Large",
          "size": "5rem"
        }
      ]
    },
    "typography": {
      "fluid": true,
      "fontFamilies": [
        {
          "slug": "system",
          "name": "System",
          "fontFamily": "-apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif"
        }
      ],
      "fontSizes": [
        {
          "slug": "small",
          "name": "Small",
          "size": "0.875rem"
        },
        {
          "slug": "medium",
          "name": "Medium",
          "size": "1rem"
        },
        {
          "slug": "large",
          "name": "Large",
          "size": "clamp(1.5rem, 3vw, 2.25rem)"
        },
        {
          "slug": "hero",
          "name": "Hero",
          "size": "clamp(2.5rem, 8vw, 6rem)"
        }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "var:preset|color|background",
      "text": "var:preset|color|foreground"
    },
    "typography": {
      "fontFamily": "var:preset|font-family|system",
      "fontSize": "var:preset|font-size|medium",
      "lineHeight": "1.6"
    },
    "spacing": {
      "blockGap": "var:preset|spacing|40"
    },
    "elements": {
      "button": {
        "border": {
          "radius": "0.5rem"
        },
        "color": {
          "background": "var:preset|color|primary",
          "text": "#ffffff"
        },
        "typography": {
          "fontWeight": "600"
        }
      },
      "link": {
        "color": {
          "text": "var:preset|color|primary"
        }
      }
    },
    "blocks": {
      "core/post-title": {
        "typography": {
          "lineHeight": "1.15"
        }
      }
    }
  },
  "templateParts": [
    {
      "name": "header",
      "title": "Header",
      "area": "header"
    },
    {
      "name": "footer",
      "title": "Footer",
      "area": "footer"
    }
  ]
}
